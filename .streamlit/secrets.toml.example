# Streamlit Community Cloud secrets format.
# DO NOT commit a real secrets.toml (it's gitignored). Instead, paste these
# key=value lines into the "Secrets" box in your app's settings on
# https://share.streamlit.io  ->  Manage app  ->  Settings  ->  Secrets.
#
# Streamlit exposes top-level keys as environment variables too, so the app's
# os.getenv("DEEPSEEK_API_KEY") picks them up with no code changes.

DEEPSEEK_API_KEY = "sk-your-real-deepseek-key"
DEEPSEEK_MODEL = "deepseek-v4-flash"
