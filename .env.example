DEEPSEEK_V4_FLASH_INPUT_CACHE_MISS_PER_1M=0.14
DEEPSEEK_V4_FLASH_OUTPUT_PER_1M=0.28
DEEPSEEK_V4_PRO_INPUT_CACHE_HIT_PER_1M=0.003625
DEEPSEEK_V4_PRO_INPUT_CACHE_MISS_PER_1M=0.435
DEEPSEEK_V4_PRO_OUTPUT_PER_1M=0.87
