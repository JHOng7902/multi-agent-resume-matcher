DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional pricing overrides in USD per 1M tokens.
# Defaults follow the DeepSeek API pricing page at the time this project was built.
